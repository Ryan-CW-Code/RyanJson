"\x00\x00\x00\x00"
"\x00\x00\x00\x00\x00\x00\x00\x00"
"\x00\x00\x00\x00\x00\x00\x00\x01"
"\x01\x00\x00\x00\x00\x00\x00\x00"
"\x10\x00\x00\x00\x00\x00\x00\x00"

"\xff\xff"
"\xfe\xff\xff\xee"
"\xff\xff\xff\xff"
"\xfe\xff\xff\xff\xff\xff\xff\xfa"
